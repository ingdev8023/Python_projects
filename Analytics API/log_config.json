{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "format": "%(asctime)s %(levelname)s %(name)s %(message)s"
    }
  },
  "handlers": {
    "file": {
      "class": "logging.FileHandler",
      "filename": "server.log",
      "formatter": "default"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["file"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["file"],
      "level": "ERROR",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["file"],
      "level": "INFO",
      "propagate": false
    }
  }
}